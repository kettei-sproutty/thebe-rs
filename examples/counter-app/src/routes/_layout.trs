<style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: system-ui, sans-serif;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
}

header nav {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 2rem;
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(4px);
}

header nav a {
    color: inherit;
    text-decoration: none;
    font-weight: 500;
    opacity: 0.85;
    transition: opacity 0.15s;
}

header nav a:hover {
    opacity: 1;
}

footer {
    margin-top: auto;
    padding: 1rem 2rem;
    text-align: center;
    font-size: 0.85rem;
    opacity: 0.6;
}
</style>
