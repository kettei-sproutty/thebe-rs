<script setup>
struct Props;
#[thebe::get]
pub fn handler() -> Props {
  Props
}
</script>

<head>
    <title>Auth</title>
    <meta name="description" content="A user authentication page demonstrating Thebe's support for TypeScript in components." />
</head>

<script lang="ts">
function handleLogin(event: Event) {
    event.preventDefault();
    const form = event.target as HTMLFormElement;
    const formData = new FormData(form);
    const username = formData.get("username");
    alert(`Welcome, ${username}! This is a placeholder login action.`);
}
</script>

<main>
    <h1>Login</h1>
    <p>This is a placeholder login page to demonstrate Thebe's support for TypeScript in components. In a real application, you would implement proper authentication logic here.</p>
    <form onsubmit="handleLogin">
        <div class="form-group">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required />
        </div>
        <div class="form-group">
            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required />
        </div>
        <button type="submit">Login</button>
    </form>
</main>
