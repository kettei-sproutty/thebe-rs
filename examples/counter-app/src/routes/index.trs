    font-size: 2rem;
    margin-bottom: 1rem;
}

.count {
    font-size: 4rem;
    font-weight: bold;
    margin: 1rem 0;
}

.controls {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
}

button {
    width: 3rem;
    height: 3rem;
    font-size: 1.5rem;
    border: 2px solid #1a1a1a;
    background: white;
    border-radius: 0.5rem;
    cursor: pointer;
}

button:hover {
    background: #1a1a1a;
