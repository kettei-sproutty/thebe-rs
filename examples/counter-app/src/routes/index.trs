<script setup>
use rand::RngExt;

struct Props {
    title: String,
    count: u32,
}

#[thebe::get]
pub fn handler() -> Props {
  let mut rng = rand::rng();
  let random_number: u32 = rng.random();

  Props {
    title: "Thebe Counter".to_string(),
    count: random_number
  }
}
</script>

<script lang="ts">
let props = getProps<Props>();

function increment() {
    props.count += 1;
}

function decrement() {
    props.count -= 1;
}

function reset() {
    props.count = 0;
}
</script>

<main>
    <h1>{{ title }}, World!</h1>
    <nav>
        <a href="/about">About</a>
    </nav>
     <div class="controls">
      <button onclick="decrement">−</button>
      <button onclick="increment">+</button>
      <button onclick="reset">Reset</button>
    </div>
    <div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem;">
      <p class="count">{{ count }}!!</p>
    </div>

</main>

