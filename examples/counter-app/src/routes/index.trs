<script setup>
use axum::extract::State;

struct Props {
    title: String,
    count: i64,
}

#[thebe::get]
pub fn handler(State(state): State<crate::AppState>) -> Props {
  Props {
    title: "Thebe Counter".to_string(),
    count: state.count()
  }
}
</script>

<head>
  <title>{{ title }}</title>
  <meta name="description" content="A server-backed counter demo for Thebe using Axum state." />
</head>

<script lang="ts">
let props = getProps<Props>();

async function requestCount(path) {
    try {
        let response = await fetch(path, { method: "POST" });
        if (!response.ok) {
            throw new Error(`Counter request failed: ${response.status}`);
        }

        let payload = await response.json();
        props.count = payload.count;
    } catch (error) {
        console.error(error);
    }
}

function increment() {
    void requestCount("/api/counter/increment");
}

function decrement() {
    void requestCount("/api/counter/decrement");
}

function reset() {
    void requestCount("/api/counter/reset");
}
</script>

<main>
    <h1>{{ title }}</h1>
    <nav>
        <a href="/about">About</a>
    </nav>
    <p class="hint">The count lives in Axum state. Buttons post to the server and hydrate the returned value.</p>
     <div class="controls">
      <button onclick="decrement">−</button>
      <button onclick="increment">+</button>
      <button onclick="reset">Reset</button>
    </div>
    <div style="display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem;">
      <p class="count">{{ count }}</p>
    </div>
</main>

<style>

main {
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-family: system-ui, sans-serif;
}

h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.hint {
  max-width: 28rem;
  text-align: center;
  color: #555;
  margin: 0 0 1.5rem;
  line-height: 1.5;
}

.count {
    font-size: 4rem;
    font-weight: bold;
    margin: 1rem 0;
}

.controls {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
}

button {
    height: 3rem;
    font-size: 1.5rem;
    border: 2px solid #1a1a1a;
    background: white;
    border-radius: 0.5rem;
    cursor: pointer;
}

button:hover {
    background: #1a1a1a;
    color: white;
}

nav a {
    color: #555;
    text-decoration: none;
    font-size: 0.9rem;
}

nav a:hover {
    text-decoration: underline;
}
</style>
