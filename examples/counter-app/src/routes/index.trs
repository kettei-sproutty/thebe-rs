<script setup>
use axum::extract::State;

struct Props {
    title: String,
    count: i64,
}

#[thebe::get]
pub fn handler(State(state): State<crate::AppState>) -> Props {
  Props {
    title: "Thebe Counter".to_string(),
    count: state.count()
  }
}
</script>

<head>
  <title>{{ title }}</title>
  <meta name="description" content="A server-backed counter demo for Thebe using Axum state." />
</head>

<script lang="ts">
performance.mark("framework-bench:bootstrap:start");

type FrameworkBench = {
    framework: string,
    writeCount(value: number): void | Promise<void>,
    readCount(): string | null | Promise<string | null>,
}

let props = getProps<Props>();

let benchWindow = window as Window & {
    __frameworkBench?: FrameworkBench,
};

function readRenderedCount() {
    let el = document.querySelector("[data-framework-bench-counter]");
    return el ? el.textContent?.trim() ?? null : null;
}

benchWindow.__frameworkBench = {
    framework: "thebe",
    writeCount(value) {
        props.count = value;
    },
    readCount() {
        return readRenderedCount();
    }
};

queueMicrotask(() => {
    performance.mark("framework-bench:bootstrap:ready");
    performance.measure(
        "framework-bench:bootstrap",
        "framework-bench:bootstrap:start",
        "framework-bench:bootstrap:ready"
    );
});

async function requestCount(path) {
    try {
        let response = await fetch(path, { method: "POST" });
        if (!response.ok) {
            throw new Error(`Counter request failed: ${response.status}`);
        }

        let payload = await response.json();
        props.count = payload.count;
    } catch (error) {
        console.error(error);
    }
}

function increment() {
    void requestCount("/api/counter/increment");
}

function decrement() {
    void requestCount("/api/counter/decrement");
}

function reset() {
    void requestCount("/api/counter/reset");
}
</script>

<div class="flex flex-col items-center justify-center flex-grow py-12">
    <h1 class="text-4xl font-bold text-slate-900 mb-6">{{ title }}</h1>

    <p class="text-center text text-slate-500 max-w-md mb-10 leading-relaxed text-lg">
        The count lives in Axum state. Buttons post to the server and hydrate the returned value.
    </p>

    <div class="bg-white px-12 py-10 rounded-2xl shadow-sm border border-slate-200 flex flex-col items-center">
        <p data-framework-bench-counter class="text-7xl font-extrabold text-indigo-600 mb-8 tracking-tighter">{{ count }}</p>

        <div class="flex gap-4">
            <button onclick="decrement" class="h-12 w-16 text-2xl font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 hover:text-slate-900 rounded-xl transition-all shadow-sm active:scale-95">−</button>
            <button onclick="reset" class="h-12 px-6 text-sm font-semibold text-slate-500 border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 rounded-xl transition-all active:scale-95 uppercase tracking-wide">Reset</button>
            <button onclick="increment" class="h-12 w-16 text-2xl font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-all shadow-sm shadow-indigo-200 active:scale-95">+</button>
        </div>
    </div>
</div>
