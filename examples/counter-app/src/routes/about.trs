<script setup>
struct Props {
    name: String,
    tagline: String,
}

#[thebe::get]
pub fn handler() -> Props {
    Props {
        name: "Thebe".to_string(),
        tagline: "A compiler-driven full-stack Rust web framework using Single File Components.".to_string(),
    }
}
</script>

<head>
    <title>About {{ name }}</title>
    <meta name="description" content="{{ tagline }}" />
</head>

<main>
    <h1>About {{ name }}</h1>
    <p>{{ tagline }}</p>
    <ul>
        <li>Server-side rendering via Axum</li>
        <li>Fine-grained client reactivity — no virtual DOM</li>
        <li>Single File Components (<code>.trs</code>)</li>
        <li>Zero config — just run <code>thebe dev</code></li>
    </ul>
</main>

