<script setup>
use reqwest::Client;
use anyhow::Result;

async fn fetch_title() -> Result<String> {
    let client = Client::new();
    let response = client.get("https://api.example.com/data").send().await?;
    let data = response.text().await?;
    Ok(data)
}

struct Props {
  title: String,
  counter: i32,
}

#[thebe::get]
pub fn handler() -> Props {

  let title = fetch_title();

  Props {
   title: "Hello, Thebe!".to_string(),
   counter: 0,
  }
}
</script>

<script lang="ts">
  let { counter } = getProps<Props>();

  function increment() {
    counter += 1;
  }

  function decrement() {
    counter -= 1;
  }
</script>

<h1>{{ title }}</h1>
<button onclick="increment">+1</button>
<button onclick="decrement">-1</button>
<span>Counter: {{ counter }}</span>

<style>
  h1 {
    color: blue;
  }

  button {
    margin: 5px;
  }
</style>
