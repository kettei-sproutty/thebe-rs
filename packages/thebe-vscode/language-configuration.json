{
  "comments": {
    "blockComment": [
      "<!--",
      "-->"
    ]
  },
  "brackets": [
    [
      "<",
      ">"
    ],
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "<",
      "close": ">",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "{",
      "close": "}",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    }
  ],
  "surroundingPairs": [
    [
      "<",
      ">"
    ],
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([:\\w][:\\w.-]*)"
}
